# Supabase — SOLO servidor (sin prefijo VITE_; no van al bundle del navegador).
# En local: apps/web/.env.local
# Supabase → Project Settings → API

SUPABASE_URL=https://tu-proyecto.supabase.co
SUPABASE_ANON_KEY=tu_clave_publica_anon_o_publishable
# Registro: la confirmación de email la envía Supabase (no Nexa SMTP).
# En dev, desactivá "Confirm email" en Supabase → Authentication → Email.

# Storage: bucket con prefijos profiles/ y events/
SUPABASE_STORAGE_BUCKET=nexa-uploads

# PostgreSQL (Drizzle) — REQUERIDO para la app
# Runtime: Transaction pooler (puerto 6543, ?pgbouncer=true)
DATABASE_URL="postgresql://postgres.[ref]:[PASSWORD]@aws-0-[region].pooler.supabase.com:6543/postgres?pgbouncer=true"
# Migraciones y seed (Session pooler 5432 si db.[ref] falla con ENOTFOUND)
DIRECT_URL="postgresql://postgres.[ref]:[PASSWORD]@aws-0-[region].pooler.supabase.com:5432/postgres"

# Google Maps (opcional, para /mapa con apariencia Google)
VITE_GOOGLE_MAPS_API_KEY=
VITE_GOOGLE_MAPS_MAP_ID=DEMO_MAP_ID

# Contraseña para usuarios de demo creados por `bun run db:seed` (no commitear el valor real)
SEED_DEV_PASSWORD=

# Usuarios de demo (crear en Supabase Auth con estos UUID como id; ver packages/database/scripts/seed.ts)
# asistente@nexa.mock / organizador@nexa.mock / emprendedor@nexa.mock
# user_metadata: { "role": "asistente"|"organizador"|"emprendedor", "displayName": "..." }

# URL pública de la app (links en emails de recomendación)
APP_URL=http://localhost:3000

# Emails de recomendación de eventos (ver README.md)
# console = imprime el email en la terminal (desarrollo local)
# smtp    = envío real vía Nodemailer (Gmail SMTP)
EMAIL_PROVIDER=console
# EMAIL_FROM="Nexa <tu@gmail.com>"
# SMTP_USER=tu@gmail.com
# SMTP_PASS=xxxx xxxx xxxx xxxx
# SMTP_HOST=smtp.gmail.com
# SMTP_PORT=587

# Secreto para disparar envíos batch vía server function (cron / jobs)
# RECOMMENDATION_EMAIL_CRON_SECRET=

