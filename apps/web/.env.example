# Supabase — SOLO servidor (sin prefijo VITE_; no van al bundle del navegador).
# En local: apps/web/.env.local o variables del host (Netlify, etc.).
# Supabase → Project Settings → API

SUPABASE_URL=https://tu-proyecto.supabase.co
SUPABASE_ANON_KEY=tu_clave_publica_anon_o_publishable

# Storage: un bucket con prefijos profiles/ y events/, o buckets separados
SUPABASE_STORAGE_BUCKET=nexa-uploads
# SUPABASE_STORAGE_BUCKET_PROFILES=nexa-profiles
# SUPABASE_STORAGE_BUCKET_EVENTS=nexa-events
#
# En Supabase Dashboard → Storage: crear bucket(s) y políticas RLS para rol authenticated.
# Mientras el login use mock, las subidas usan URLs locales; con sesión Supabase van al bucket.

# PostgreSQL (Prisma) — SOLO servidor. Supabase → Project Settings → Database
# Runtime: Transaction pooler (puerto 6543, ?pgbouncer=true)
# DATABASE_URL="postgresql://postgres.[ref]:[PASSWORD]@aws-0-[region].pooler.supabase.com:6543/postgres?pgbouncer=true"
# Migraciones: conexión directa (puerto 5432)
# DIRECT_URL="postgresql://postgres:[PASSWORD]@db.[ref].supabase.co:5432/postgres"

# Google Maps ya viene en apps/web/.env.local del repo (materia).

# Google Maps (opcional, para /mapa con apariencia Google)
# 1. https://console.cloud.google.com/ → APIs → habilitar "Maps JavaScript API"
# 2. Credenciales → API key → restringir por dominio en producción
# 3. Map Management → crear Map ID (o usar DEMO_MAP_ID solo en local)
VITE_GOOGLE_MAPS_API_KEY=
VITE_GOOGLE_MAPS_MAP_ID=DEMO_MAP_ID
