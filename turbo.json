{
  "$schema": "https://turbo.build/schema.json",
  "ui": "tui",
  "tasks": {
    "build": {
      "dependsOn": ["^build"],
      "inputs": ["$TURBO_DEFAULT$", ".env*"],
      "outputs": [".output/**"],
      "env": [
        "RECOMMENDATION_EMAIL_CRON_SECRET",
        "VITE_GOOGLE_MAPS_API_KEY",
        "VITE_GOOGLE_MAPS_MAP_ID",
        "DATABASE_URL",
        "DIRECT_URL",
        "SUPABASE_STORAGE_BUCKET",
        "SUPABASE_URL",
        "SUPABASE_ANON_KEY",
        "EMAIL_PROVIDER",
        "EMAIL_FROM",
        "SMTP_USER",
        "SMTP_PASS"
      ]
    },
    "db:generate": {
      "cache": false,
      "outputs": ["drizzle/**"]
    },
    "lint": {
      "dependsOn": ["^lint"]
    },
    "format": {
      "dependsOn": ["^format"]
    },
    "typecheck": {
      "dependsOn": ["^typecheck"]
    },
    "dev": {
      "cache": false,
      "persistent": true
    }
  }
}
